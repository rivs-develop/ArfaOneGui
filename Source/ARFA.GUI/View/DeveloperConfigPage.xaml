<Page x:Class="RIVS.ASAK.ARFA.GUI.View.DeveloperConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      Title="DeveloperConfigPage">
    <Page.Resources>
        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border BorderThickness="2" BorderBrush="White" Background="Transparent">
                            <TextBlock x:Name="ContentHeader" FontSize="20" Text="{TemplateBinding Content}" TextAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="White"/>
        </Style>
    </Page.Resources>
    <Grid Margin="74,20,10,0" VerticalAlignment="Top">
        <TextBlock TextWrapping="WrapWithOverflow" FontSize="15" Margin="0,10,0,0" TextAlignment="Left" FontWeight="Bold"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White">
        ВНИМАНИЕ!<LineBreak/>Обновление конфигурации во время измерения недопустимо.<LineBreak/>Дождитесь окончания цикла измерений.
        </TextBlock>
        <GroupBox Header="АП" HorizontalAlignment="Left" Margin="0,75,0,0" VerticalAlignment="Top"
                  Width="600" Foreground="White" FontSize="20">
            <Grid Margin="5" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="1" >
                    <Label Content="Текущая АП:" Foreground="White"/>
                    <Border BorderThickness="1" BorderBrush="White" Width="190" Height="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="145,5,5,5">
                        <TextBlock VerticalAlignment="Stretch" HorizontalAlignment="Stretch" TextAlignment="Center"
                                   FontSize="17" Text="{Binding ApName}" Foreground="White"/>
                    </Border>

                </Grid>
                <!--<Button Grid.Row="2"  x:Name="UpdateApButton" BorderThickness="1"
                        Click="UpdateApButton_Click" Visibility="Visible" Margin="10,9" Content="Обновить АП"/>-->
                <Grid Grid.Row="0" HorizontalAlignment="Stretch" Margin="5">
                    <Button x:Name="UpdateApButton" BorderThickness="1" Width="100" HorizontalAlignment="Left"
                        Click="UpdateApButton_Click" Visibility="Visible" Height="40"
                            VerticalContentAlignment="Center"  Content="Обновить"/>
                    <Label HorizontalAlignment="Left" Margin="140,5,5,5" Width="190" VerticalAlignment="Top"
                           Height="30" Foreground="White"/>
                </Grid>
                
                
                <!--<Button Grid.Row="4" Margin="10,9" x:Name="UpdateElementsButton" BorderThickness="1"
                        Click="UpdateElementsButton_Click" Content="Обновить элементы"/>-->
                <!--<Grid Grid.Row="5" HorizontalAlignment="Center">
                    <Label Content="" Foreground="White" />
                </Grid>-->
            </Grid>
        </GroupBox>
        <GroupBox Header="Элементы" HorizontalAlignment="Left" Margin="0,220,0,0"
                  VerticalAlignment="Top" Foreground="White" FontSize="20">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="1" >
                    <ListView Background="Transparent" ItemsSource="{Binding ActiveElementsCollection}"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="0" Margin="3,10,0,10" PreviewMouseWheel="ListView_PreviewMouseWheel">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Setter Property="Height" Value="25" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FontSize" Value="17"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="White"/>
                                <!-- Переопределяем ControlTemplate -->
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListViewItem}">
                                            <Border Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="0">
                                                <GridViewRowPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="White" />
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="White" />
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ID}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Name" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Start" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Start}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Stop" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Stop}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="RO1" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RO1}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="RO2" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RO2}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="CeN" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CeN}" TextAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
                <Grid Grid.Row="0" Margin="5" VerticalAlignment="Stretch" HorizontalAlignment="Left">
                    <Button x:Name="UpdateElementsButton" BorderThickness="1" Width="100" Height="40"
                            VerticalContentAlignment="Center" Content="Обновить" HorizontalAlignment="Left"
                        Click="UpdateElementsButton_Click" Visibility="Visible" />
                    <Label HorizontalAlignment="Left" Width="190" Margin="140,0,0,0"
                           VerticalAlignment="Top" Height="30" Foreground="White"/>
                </Grid>
            </Grid>
        </GroupBox>
    </Grid>
</Page>
