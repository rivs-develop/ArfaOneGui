<Window x:Class="RIVS.ASAK.UIElements.Confirmation.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RIVS.ASAK.UIElements.Confirmation"
        mc:Ignorable="d"
        Title="Подтверждение"
        Height="240"
        Width="420"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None" BorderThickness="1" 
        Background="#FF2D2D30">

    <Border BorderBrush="#FF007ACC"
            BorderThickness="1"
            Padding="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="18"
                       Foreground="White"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="White"
                       VerticalAlignment="Center"
                       FontSize="14"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <Button Content="Нет"
                        Width="100"
                        Height="35"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Margin="0,0,10,0"
                        Click="No_Click"/>

                <Button Content="Да"
                        Width="100"
                        Height="35"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="#0078D7"
                        Foreground="White"
                        Click="Yes_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
